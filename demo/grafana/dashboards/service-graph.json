{
  "title": "Service Graph",
  "uid": "service-graph",
  "schemaVersion": 39,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "title": "Service graph — request flow across services (click a node/edge to drill in)",
      "type": "nodeGraph",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "serviceMap"
        }
      ]
    },
    {
      "title": "Request rate by service (span metrics)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (service) (rate(traces_spanmetrics_calls_total[1m]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "title": "Edge request rate (caller → callee)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (client, server) (rate(traces_service_graph_request_total[1m]))",
          "legendFormat": "{{client}} → {{server}}"
        }
      ]
    }
  ]
}
