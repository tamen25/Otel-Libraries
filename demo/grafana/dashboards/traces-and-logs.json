{
  "title": "Traces & Logs Correlation",
  "uid": "traces-logs-correlation",
  "schemaVersion": 39,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "service_name", "stream": "", "type": 1 },
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "trace_id",
        "type": "textbox",
        "label": "Trace ID filter (regex)",
        "query": ".+",
        "current": { "text": ".+", "value": ".+" }
      }
    ]
  },
  "panels": [
    {
      "title": "Distributed traces — click a Trace ID to open the full trace",
      "type": "table",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{}",
          "limit": 20,
          "tableType": "traces"
        }
      ]
    },
    {
      "title": "Logs — click 'View trace' on any line, or paste a Trace ID above to isolate one request",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 9 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=~\"$service\"} | trace_id=~\"$trace_id\""
        }
      ]
    },
    {
      "title": "Log volume by service",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (service_name) (count_over_time({service_name=~\"$service\"}[1m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "title": "Warnings & errors",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=~\"$service\"} | detected_level=~\"error|warn\""
        }
      ]
    }
  ]
}
