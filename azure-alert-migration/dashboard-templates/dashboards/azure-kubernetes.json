          "selected": true,
          "text": "Tempo",
          "value": "tempo"
        }
      },
      {
        "name": "cmdb_reference",
        "label": "CMDB_REFERENCE",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$metrics_datasource"
        },
        "definition": "label_values(container_memory_usage_bytes, cmdbReference)",
        "query": {
          "query": "label_values(container_memory_usage_bytes, cmdbReference)",
          "refId": "cmdb_referenceVariable"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "sort": 1
      },
      {
        "name": "service_name",
        "label": "Service name",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$metrics_datasource"
        },
        "definition": "label_values(container_memory_usage_bytes{cmdbReference=~\"$cmdb_reference\"}, service_name)",
        "query": {
          "query": "label_values(container_memory_usage_bytes{cmdbReference=~\"$cmdb_reference\"}, service_name)",
          "refId": "service_nameVariable"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "sort": 1
      },
      {
