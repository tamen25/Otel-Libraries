        "datasource": {
          "type": "prometheus",
          "uid": "$metrics_datasource"
        },
        "definition": "label_values(container_memory_usage_bytes{cmdbReference=~\"$cmdb_reference\",service_name=~\"$service_name\"}, k8s_namespace_name)",
        "query": {
          "query": "label_values(container_memory_usage_bytes{cmdbReference=~\"$cmdb_reference\",service_name=~\"$service_name\"}, k8s_namespace_name)",
          "refId": "namespaceVariable"
